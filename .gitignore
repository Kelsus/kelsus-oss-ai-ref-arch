# Node
node_modules/
dist/

# Data — generated/synthetic artifacts are reproducible; don't commit bulk
data/**/output/
data/**/raw/
data/**/*.pdf
data/**/*.parquet
data/synthea/synthea/
data/synthea/synthea-with-dependencies.jar
data/gold/**/*.json
data/corpus/seed/
*.zip

# Bench outputs (raw CSVs are published deliberately, not auto-committed)
bench/reports/runs/

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Local tool settings
.claude/settings.local.json

