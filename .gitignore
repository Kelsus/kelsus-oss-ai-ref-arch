# Secrets / local config
*.tfvars
!example.tfvars
.env
.env.*
*.pem
kubeconfig*
.aws-sso-cache/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/
